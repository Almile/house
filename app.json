{
  "expo": {
    "scheme": "acme",
    "name": "House Hunt",
    "slug": "house",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icone.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icone.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B263B"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
  "adaptiveIcon": {
    "foregroundImage": "./assets/icone.png",
    "backgroundColor": "#1B263B"
  },
  "edgeToEdgeEnabled": true,
  "package": "com.almile.house",
  "config": {
    "googleMapsApiKey": "" 
  }
},

    "web": {
      "favicon": "./assets/icone.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permita que o House Hunt acesse sua localização para mapear e encontrar imóveis próximos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o House Hunt acesse sua câmera para capturar fotos dos imóveis cadastrados."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7fb11c32-f058-42f1-be46-3ef41a77295c"
      }
    }
  }
}
